  <diagram name="User Flow - Missing Front Bucket" id="userflow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="User Flow: Quality Inspection - Missing Front Bucket Scenario" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- ============== PHASE 1: USER INPUT ============== -->
        <mxCell id="phase1_label" value="PHASE 1: User Input" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: User -->
        <mxCell id="user" value="User" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="40" height="60" as="geometry" />
        </mxCell>

        <!-- Step 2: Upload Image -->
        <mxCell id="step1" value="1. Upload Image&#xa;&#xa;User uploads photo of&#xa;LEGO Technic model&#xa;(missing front bucket)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="120" width="150" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow: User to Upload -->
        <mxCell id="arrow1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="user" target="step1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Click Generate -->
        <mxCell id="step2" value="2. Click Button&#xa;&#xa;&quot;Generate Inspection&#xa;Report&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============== PHASE 2: VIEW DETECTION ============== -->
        <mxCell id="phase2_label" value="PHASE 2: View Detection (Gemini)" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Step 4: Detect View -->
        <mxCell id="step3" value="3. detect_view_angle()&#xa;&#xa;Gemini analyzes image&#xa;orientation and returns:&#xa;&#xa;&quot;FrontLeft&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="300" width="160" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- View Detection Details -->
        <mxCell id="view_detail" value="Prompt to Gemini:&#xa;&quot;What view angle is this?&#xa;Options: Front, Rear, Left,&#xa;Right, FrontLeft, FrontRight...&quot;&#xa;&#xa;Response: &quot;FrontLeft&quot;" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=5;spacingTop=5;opacity=70;" vertex="1" parent="1">
          <mxGeometry x="320" y="300" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- ============== PHASE 3: VISIBILITY FILTERING ============== -->
        <mxCell id="phase3_label" value="PHASE 3: Visibility Filtering (MCP Tools)" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- Step 5: Get Visible Parts -->
        <mxCell id="step4" value="4. mcp_tools.get_visible_parts()&#xa;&#xa;doc_name: &quot;JCB_Model&quot;&#xa;view_name: &quot;FrontLeft&quot;&#xa;side_threshold: 5.0mm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="500" width="180" height="110" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: RPC Call -->
        <mxCell id="step5" value="5. XML-RPC to FreeCAD&#xa;&#xa;get_all_parts_mapping()&#xa;Returns bounding boxes&#xa;for all 45 parts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="360" y="500" width="160" height="110" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow5" value="port 9875" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 7: Filter Logic -->
        <mxCell id="step6" value="6. _filter_by_view_visibility()&#xa;&#xa;For FrontLeft view:&#xa;- Show front-facing parts&#xa;- Show left-facing parts&#xa;- Hide rear/right parts&#xa;- Hide internal parts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="560" y="500" width="180" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Filter Result Box -->
        <mxCell id="filter_result" value="Filter Result:&#xa;&#xa;Total parts: 45&#xa;Visible: 28 (for FrontLeft)&#xa;Hidden: 17&#xa;&#xa;Visible includes:&#xa;- Front_Bucket ← EXPECTED&#xa;- Left_Wheel_Front&#xa;- Cabin_Frame&#xa;- Engine_Hood&#xa;..." style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="480" width="180" height="170" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step6" target="filter_result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============== PHASE 4: AI ANALYSIS ============== -->
        <mxCell id="phase4_label" value="PHASE 4: Image Analysis (Gemini)" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- Step 8: Build Context -->
        <mxCell id="step7" value="7. get_model_context()&#xa;&#xa;Build parts list with ONLY&#xa;visible parts for Gemini:&#xa;&#xa;28 parts with descriptions&#xa;(excludes hidden 17 parts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="730" width="180" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="filter_result" target="step7">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="870" y="680" />
              <mxPoint x="230" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 9: Gemini Analysis -->
        <mxCell id="step8" value="8. Gemini Image Analysis&#xa;&#xa;Input:&#xa;- User's uploaded image&#xa;- Filtered parts list (28)&#xa;- System prompt&#xa;&#xa;Task: Compare image vs&#xa;expected parts list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
