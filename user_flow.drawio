        <mxCell id="leg1" value="Green = Streamlit UI" style="text;strokeColor=none;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="legend">
          <mxGeometry y="26" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="Blue = MCP Tools" style="text;strokeColor=none;fillColor=#dae8fc;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="legend">
          <mxGeometry y="50" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="Yellow = Gemini AI" style="text;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="legend">
          <mxGeometry y="74" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="Purple = FreeCAD RPC" style="text;strokeColor=none;fillColor=#e1d5e7;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="legend">
          <mxGeometry y="98" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="leg5" value="Gray = Output/Display" style="text;strokeColor=none;fillColor=#f5f5f5;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="legend">
          <mxGeometry y="122" width="200" height="24" as="geometry" />
        </mxCell>

        <!-- Key Insight Box -->
        <mxCell id="insight" value="KEY INSIGHT: View Filtering&#xa;&#xa;Without filtering, Gemini would&#xa;receive ALL 45 parts and might&#xa;incorrectly report parts that are&#xa;simply not visible from FrontLeft&#xa;view (like Rear_Axle, Right_Mirror).&#xa;&#xa;By filtering to 28 visible parts,&#xa;the AI only checks for parts that&#xa;SHOULD be visible, reducing&#xa;false positives significantly." style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;spacingTop=8;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="1000" y="260" width="220" height="200" as="geometry" />
        </mxCell>

        <!-- Timing Box -->
        <mxCell id="timing" value="Typical Timing&#xa;&#xa;Phase 1: ~0.1s (upload)&#xa;Phase 2: ~1.5s (Gemini view)&#xa;Phase 3: ~0.3s (MCP filter)&#xa;Phase 4: ~3.0s (Gemini analysis)&#xa;Phase 5: ~0.5s (render CAD)&#xa;Phase 6: ~0.1s (display)&#xa;&#xa;Total: ~5-6 seconds" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="490" width="180" height="180" as="geometry" />
        </mxCell>

        <!-- Data Flow Summary -->
