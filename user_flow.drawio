        <!-- Arrow -->
        <mxCell id="arrow11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="gemini_response" target="step9">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="660" y="900" />
              <mxPoint x="220" y="900" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 11: Render Overview -->
        <mxCell id="step10" value="10. render_model_with_highlights()&#xa;&#xa;mcp_tools.get_view_screenshot()&#xa;view: &quot;FrontLeft&quot;&#xa;highlight: [&quot;Front_Bucket&quot;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="340" y="950" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step9" target="step10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 12: RPC Screenshot -->
        <mxCell id="step11" value="11. XML-RPC Screenshot&#xa;&#xa;FreeCAD renders view&#xa;with custom quaternion:&#xa;(0.175, 0.424, 0.339, 0.820)&#xa;&#xa;Returns base64 PNG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="580" y="940" width="180" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow13" value="port 9875" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step10" target="step11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============== PHASE 6: DISPLAY REPORT ============== -->
        <mxCell id="phase6_label" value="PHASE 6: Display Report" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1080" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Step 13: Display Report -->
        <mxCell id="step12" value="12. display_inspection_report()&#xa;&#xa;Show side-by-side:&#xa;- User's uploaded image&#xa;- CAD reference (FrontLeft)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="1130" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="step11" target="step12">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="1080" />
              <mxPoint x="240" y="1080" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Final Output Box -->
        <mxCell id="output" value="QUALITY INSPECTION REPORT&#xa;&#xa;Input / Output Comparison&#xa;┌─────────────┬─────────────┐&#xa;│ User Image  │ CAD Ref     │&#xa;│ (uploaded)  │ (FrontLeft) │&#xa;└─────────────┴─────────────┘&#xa;&#xa;Missing Parts Detected:&#xa;✗ Front_Bucket - MISSING&#xa;&#xa;Inspection Notes:&#xa;The front loader bucket is not&#xa;present in the assembled model.&#xa;This is a critical structural&#xa;component needed for the JCB&#xa;loader functionality." style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="1100" width="260" height="260" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="step12" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- User sees result -->
        <mxCell id="user_end" value="User" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="1180" width="40" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow -->
        <mxCell id="arrow16" value="Views Report" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="output" target="user_end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============== LEGEND ============== -->
        <mxCell id="legend" value="Legend" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=0;marginBottom=0;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1000" y="80" width="200" height="150" as="geometry" />
