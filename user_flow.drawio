        <!-- ============== PHASE 5: RENDER CAD REFERENCE ============== -->
        <mxCell id="phase5_label" value="PHASE 5: Render CAD Reference (MCP Tools)" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="900" width="320" height="30" as="geometry" />
        </mxCell>

        <!-- Step 10: Extract Parts -->
        <mxCell id="step9" value="9. extract_mentioned_parts()&#xa;&#xa;Parse Gemini response&#xa;to find: &quot;Front_Bucket&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=center;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="140" y="950" width="160" height="90" as="geometry" />
